# Copy this file to .env and fill in your values.
# Real keys live in ~/.secrets — sourced automatically in every terminal.
# This file documents which keys THIS project needs.
# bun auto-loads .env — no dotenv needed.

ANTHROPIC_API_KEY=           # Required — LLM-as-judge evals (bun run test:evals)
OPENAI_API_KEY=              # Optional — Codex E2E tests (test/codex-e2e.test.ts)
GEMINI_API_KEY=              # Optional — Gemini E2E tests (test/gemini-e2e.test.ts)
